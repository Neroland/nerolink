{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "NeroLink - multiloader build (Fabric).",
  "authors": ["${mod_authors}"],
  "license": "${mod_license}",
  "icon": "nerolink_logo.png",
  "accessWidener": "nerolink.accesswidener",
  "environment": "*",
  "entrypoints": {
    "main": ["za.co.neroland.nerolink.fabric.NeroLinkFabric"],
    "client": ["za.co.neroland.nerolink.fabric.NeroLinkFabricClient"]
  },
  "mixins": [
    "nerolink-common.mixins.json",
    "nerolink.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*",
    "nerolandcore": ">=${nerolandcore_version}"
  }
}
